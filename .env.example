# ─── WhatsApp Business API (Meta) ───────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=        # ID del número en Meta Developers
WHATSAPP_ACCESS_TOKEN=           # Token permanente de usuario del sistema
WHATSAPP_VERIFY_TOKEN=           # Token secreto para verificar el webhook (lo inventás vos)

# ─── Supabase ───────────────────────────────────────────────────
SUPABASE_URL=                    # URL del proyecto Supabase
SUPABASE_SERVICE_ROLE_KEY=       # Service role key (SOLO servidor, nunca exponer)
NEXT_PUBLIC_SUPABASE_URL=        # Misma URL (para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=   # Anon key pública

# ─── OpenRouter (DeepSeek) ──────────────────────────────────────
OPENROUTER_API_KEY=              # Key de OpenRouter
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324

# ─── Resend (emails de notificación) ────────────────────────────
RESEND_API_KEY=                  # Key de Resend
NOTIFY_EMAIL=                    # Email(s) separados por coma para alertas
RESEND_FROM=Berta <berta@tudominio.com>

# ─── Brevo (email marketing / importador masivo) ────────────────
BREVO_API_KEY=                   # API key v3 de Brevo (Configuración → SMTP & API → API Keys)
BREVO_WEBHOOK_SECRET=            # Secret para validar el webhook entrante de Brevo

# ─── Seguridad / Crons ──────────────────────────────────────────
CRON_SECRET=                     # String secreto para autenticar los crons de Vercel
ALLOWED_EMAIL_DOMAIN=tudominio.com   # Solo estos emails pueden entrar al panel

# ─── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
CALENDLY_URL=https://calendly.com/tu-usuario/30min
